# Server Configuration
ENV=development
PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=30s
METRICS_PORT=9090

# Database
DATABASE_URL=postgres://msgnr:msgnr@localhost/msgnr?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=1m
DB_CONNECT_TIMEOUT=10s

# JWT Secret (change this in production)
JWT_SECRET=your-secret-key-change-this
JWT_ACCESS_TOKEN_TTL=1h
JWT_REFRESH_TOKEN_TTL=168h

# LiveKit Configuration
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
# Optional extra header check for incoming webhook requests.
# LiveKit already signs webhooks with Authorization JWT using API key/secret.
# Leave blank unless your LiveKit setup also sends X-LiveKit-Webhook-Secret.
LIVEKIT_WEBHOOK_SECRET=
CALL_INVITE_TTL=60s

# Sync and bootstrap policy
SYNC_EVENT_LIMIT=1000
SYNC_RETENTION_WINDOW=72
MAX_SYNC_BATCH=500
BOOTSTRAP_DEFAULT_PAGE_SIZE=100
BOOTSTRAP_MAX_PAGE_SIZE=200
BOOTSTRAP_SESSION_TTL=5m
CHAT_HISTORY_PAGE_SIZE=50

# Minio / Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=task-attachments
ATTACHMENT_MAX_SIZE_MB=50
AVATAR_MAX_SIZE_MB=5

# Phase 3: event pipeline
WS_OUTBOUND_QUEUE_MAX=1024
EVENT_BUS_SUBSCRIBER_BUFFER=256
EVENT_LISTENER_CATCHUP_BATCH=500
EVENT_LISTENER_RETRY_BACKOFF=1s
