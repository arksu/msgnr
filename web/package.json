{
  "name": "msgnr-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "tauri:dev": "npm exec tauri dev -- --config src-tauri/tauri.conf.json",
    "tauri:build": "npm exec tauri build -- --config src-tauri/tauri.conf.json",
    "tauri:build:minor": "node scripts/tauri-build-minor.cjs",
    "proto:gen": "cd ../api/proto && buf generate",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/copy-rnnoise.cjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@emoji-mart/data": "^1.2.1",
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.13.6",
    "dexie": "^4.3.0",
    "emoji-mart-vue-fast": "^15.0.5",
    "livekit-client": "^2.15.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.49.0",
    "@bufbuild/protoc-gen-es": "^2.3.0",
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.0"
  }
}
